# Cloudgate IdP API base URL (no trailing slash)
VITE_IDP_API_URL=https://your-api-host

# Tenant slug configured in Cloudgate IdP Settings
VITE_IDP_TENANCY_NAME=your-tenant

# Display name shown in the auth portal header
VITE_IDP_APP_NAME=My App

# Required for Login/Register/password reset API calls — copy from Cloudgate
# Identity → Settings (IdP Settings) → recaptchaSecret field.
VITE_IDP_RECAPTCHA_SECRET=your-tenant-recaptcha-secret
