# Display name shown in the header, footer, and browser tab.
VITE_APP_NAME=Cloudgate App

# --- Cloudgate IdP auth ---------------------------------------------------
# Base URL of the IdP (used to build the hosted login page URL).
# Login redirects to: {VITE_IDP_BASE_URL}/idp/{tenancy}/login
VITE_IDP_BASE_URL=https://your-idp-host

# Optional: separate API base for IdP profile/refresh calls.
# Falls back to VITE_IDP_BASE_URL when empty.
VITE_IDP_API_URL=

# Tenancy name. Can be overridden at runtime via ?idp_tenant= query param
# or a subdomain (e.g. acme.example.com -> "acme").
VITE_IDP_TENANCY_NAME=your-tenant

# Optional: where the IdP should redirect back after login (appended as ?returnUrl=).
VITE_IDP_RETURN_URL=

# --- Cloudgate workflow API ----------------------------------------------
# Base URL of the Cloudgate gateway that serves your workflow endpoints.
# The React client ONLY talks to Cloudgate. Endpoints are appended, e.g.
# {base}/your-project/your-route
VITE_CLOUDGATE_API_URL=http://{tenant}.localhost:44301/sbx/api

# Gateway request-signing credentials (HMAC). Required to call signed endpoints.
VITE_API_KEY=your-api-key
VITE_API_SECRET=your-api-secret
